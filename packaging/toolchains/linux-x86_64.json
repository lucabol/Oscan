{
  "schema_version": 1,
  "target": "linux-x86_64",
  "bundle_kind": "full",
  "toolchain": {
    "vendor": "musl.cc",
    "version": "x86_64-linux-musl-cross",
    "archive": {
      "url": "https://github.com/lucabol/Oscan/releases/download/toolchains/x86_64-linux-musl-cross.tgz",
      "type": "tgz",
      "digest": null
    },
    "extract": {
      "strip_components": 1
    },
    "prune": {
      "remove_globs": [
        "lib/libstdc++*",
        "lib/libsupc++*",
        "lib/libgomp*",
        "lib/libatomic*",
        "lib/libitm*",
        "lib/libssp*",
        "lib/libquadmath*",
        "lib/libgfortran*",
        "lib/libasan*",
        "lib/liblsan*",
        "lib/libtsan*",
        "lib/libubsan*",
        "lib/libsanitizer*",
        "include/c++",
        "share/doc",
        "share/info",
        "share/man",
        "share/locale",
        "share/gcc-*"
      ],
      "strip_debug": true
    }
  },
  "stage": {
    "root": "toolchain",
    "license_globs": [
      "COPYING*",
      "COPYRIGHT*",
      "LICENSE*"
    ],
    "wrappers": [
      {
        "path": "bin/gcc",
        "kind": "posix-exec",
        "target": "x86_64-linux-musl-gcc"
      }
    ]
  }
}
