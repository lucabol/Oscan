fn! main() {
    // file_exists on self (this test file should "exist" but we test something we know)
    // Create a temp file, check it exists, rename it, check the new name exists, delete
    let fd: i32 = match file_open_write("_oscan_test_fs.tmp") {
        Result::Ok(v) => { v },
        Result::Err(e) => { println("open failed: {e}"); exit(1); 0 },
    };
    write_str(fd, "hello");
    file_close(fd);

    // file_exists
    print_bool(file_exists("_oscan_test_fs.tmp"));
    println("");

    // file_size
    let sz: i64 = file_size("_oscan_test_fs.tmp");
    print_i64(sz);
    println("");

    // file_rename
    let rename_ok: bool = match file_rename("_oscan_test_fs.tmp", "_oscan_test_fs2.tmp") {
        Result::Ok(_) => { true },
        Result::Err(_) => { false },
    };
    print_bool(rename_ok);
    println("");

    // Check new name exists, old gone
    print_bool(file_exists("_oscan_test_fs2.tmp"));
    println("");
    print_bool(file_exists("_oscan_test_fs.tmp"));
    println("");

    // dir_create and dir_remove
    let create_ok: bool = match dir_create("_oscan_test_dir") {
        Result::Ok(_) => { true },
        Result::Err(_) => { false },
    };
    print_bool(create_ok);
    println("");
    let remove_ok: bool = match dir_remove("_oscan_test_dir") {
        Result::Ok(_) => { true },
        Result::Err(_) => { false },
    };
    print_bool(remove_ok);
    println("");

    // Cleanup
    match file_delete("_oscan_test_fs2.tmp") {
        Result::Ok(_) => { },
        Result::Err(_) => { },
    };

    // dir_current returns non-empty
    let cwd: str = dir_current();
    print_bool(str_len(cwd) > 0);
    println("");

    println("fs_ok");
}
