// Test §10: abs_i32, abs_f64, mod_i32, str_to_cstr, str_len on empty,
// str_eq false, str_concat with empty, i32_to_str, arena_reset, len, push.

fn! main() {
    // abs_i32: negative, zero, positive
    print("abs_i32: ");
    print_i32(abs_i32(-42));
    print(" ");
    print_i32(abs_i32(0));
    print(" ");
    print_i32(abs_i32(7));
    println("");

    // abs_f64: negative, zero
    print("abs_f64: ");
    print_f64(abs_f64(-3.14));
    print(" ");
    print_f64(abs_f64(0.0));
    println("");

    // mod_i32: various
    print("mod_i32: ");
    print_i32(mod_i32(17, 5));
    print(" ");
    print_i32(mod_i32(10, 3));
    print(" ");
    print_i32(mod_i32(0, 7));
    println("");

    // str_to_cstr
    let cstr: str = str_to_cstr("hello");
    print("str_to_cstr: ");
    println(cstr);

    // str_len on empty string
    print("str_len_empty: ");
    print_i32(str_len(""));
    println("");

    // str_eq false case
    print("str_eq_false: ");
    print_bool(str_eq("abc", "def"));
    println("");

    // str_concat with empty strings
    print("concat_empty: ");
    let c1: str = str_concat("", "hello");
    print(c1);
    print(" ");
    let c2: str = str_concat("hello", "");
    println(c2);

    // i32_to_str: 0 and negative
    print("i32_to_str: ");
    print(i32_to_str(0));
    print(" ");
    println(i32_to_str(-99));

    // arena_reset followed by new allocation
    arena_reset();
    let mut fresh: [i32] = [];
    push(fresh, 1);
    push(fresh, 2);
    print("arena_reset_ok: ");
    print_i32(len(fresh));
    println("");

    // len on fixed-size array
    let fixed: [i32; 5] = [10, 20, 30, 40, 50];
    print("fixed_len: ");
    print_i32(len(fixed));
    println("");

    // push multiple elements
    let mut multi: [i32] = [];
    for i in 0..10 {
        push(multi, i);
    };
    print("push_10: ");
    print_i32(len(multi));
    println("");
}
