// Test: File I/O built-in functions
// Exercises: file_open_write, write_str, file_close, file_open_read, read_byte,
//            write_byte, file_delete, EOF detection, error handling

fn! main() {
    // === Test 1: write_str and read back byte-by-byte ===
    let fd_w: i32 = file_open_write("_test_io_tmp.txt");
    print("open_write ok: ");
    print_bool(fd_w >= 0);
    println("");

    write_str(fd_w, "Hi!");
    file_close(fd_w);
    println("write_str done");

    let fd_r: i32 = file_open_read("_test_io_tmp.txt");
    print("open_read ok: ");
    print_bool(fd_r >= 0);
    println("");

    // 'H' = 72, 'i' = 105, '!' = 33
    let b1: i32 = read_byte(fd_r);
    let b2: i32 = read_byte(fd_r);
    let b3: i32 = read_byte(fd_r);
    print("byte H: ");
    print_i32(b1);
    println("");
    print("byte i: ");
    print_i32(b2);
    println("");
    print("byte !: ");
    print_i32(b3);
    println("");

    // === Test 2: EOF returns -1 ===
    let eof1: i32 = read_byte(fd_r);
    print("eof: ");
    print_i32(eof1);
    println("");
    // Second EOF read also returns -1
    let eof2: i32 = read_byte(fd_r);
    print("eof again: ");
    print_i32(eof2);
    println("");
    file_close(fd_r);

    // === Test 3: write_byte and read back ===
    let fd_w2: i32 = file_open_write("_test_io_tmp.txt");
    write_byte(fd_w2, 65);
    write_byte(fd_w2, 66);
    write_byte(fd_w2, 67);
    file_close(fd_w2);

    let fd_r2: i32 = file_open_read("_test_io_tmp.txt");
    let c1: i32 = read_byte(fd_r2);
    let c2: i32 = read_byte(fd_r2);
    let c3: i32 = read_byte(fd_r2);
    let c4: i32 = read_byte(fd_r2);
    print("byte A: ");
    print_i32(c1);
    println("");
    print("byte B: ");
    print_i32(c2);
    println("");
    print("byte C: ");
    print_i32(c3);
    println("");
    print("byte eof: ");
    print_i32(c4);
    println("");
    file_close(fd_r2);

    // === Test 4: write_byte with boundary values ===
    let fd_w3: i32 = file_open_write("_test_io_tmp.txt");
    write_byte(fd_w3, 0);
    write_byte(fd_w3, 255);
    write_byte(fd_w3, 127);
    file_close(fd_w3);

    let fd_r3: i32 = file_open_read("_test_io_tmp.txt");
    print("byte 0: ");
    print_i32(read_byte(fd_r3));
    println("");
    print("byte 255: ");
    print_i32(read_byte(fd_r3));
    println("");
    print("byte 127: ");
    print_i32(read_byte(fd_r3));
    println("");
    file_close(fd_r3);

    // === Test 5: file_delete returns 0 on success ===
    let del_ok: i32 = file_delete("_test_io_tmp.txt");
    print("delete ok: ");
    print_i32(del_ok);
    println("");

    // === Test 6: open non-existent file returns -1 ===
    let fd_bad: i32 = file_open_read("_no_such_file_ever.txt");
    print("open missing: ");
    print_i32(fd_bad);
    println("");

    // === Test 7: delete non-existent file fails ===
    let del_bad: i32 = file_delete("_no_such_file_ever.txt");
    print("delete missing failed: ");
    print_bool(del_bad != 0);
    println("");

    println("all file_io tests passed");
}
