// Test: File I/O built-in functions
// Exercises: file_open_write, write_str, file_close, file_open_read, read_byte,
//            write_byte, file_delete, EOF detection, error handling

fn! main() {
    // === Test 1: write_str and read back byte-by-byte ===
    let r_w: Result<i32, str> = file_open_write("_test_io_tmp.txt");
    let fd_w: i32 = match r_w {
        Result::Ok(v) => { v },
        Result::Err(e) => { println("open_write failed: {e}"); exit(1); 0 },
    };
    println("open_write ok: true");

    write_str(fd_w, "Hi!");
    file_close(fd_w);
    println("write_str done");

    let r_r: Result<i32, str> = file_open_read("_test_io_tmp.txt");
    let fd_r: i32 = match r_r {
        Result::Ok(v) => { v },
        Result::Err(e) => { println("open_read failed: {e}"); exit(1); 0 },
    };
    println("open_read ok: true");

    // 'H' = 72, 'i' = 105, '!' = 33
    let b1: i32 = read_byte(fd_r);
    let b2: i32 = read_byte(fd_r);
    let b3: i32 = read_byte(fd_r);
    print("byte H: ");
    print_i32(b1);
    println("");
    print("byte i: ");
    print_i32(b2);
    println("");
    print("byte !: ");
    print_i32(b3);
    println("");

    // === Test 2: EOF returns -1 ===
    let eof1: i32 = read_byte(fd_r);
    print("eof: ");
    print_i32(eof1);
    println("");
    // Second EOF read also returns -1
    let eof2: i32 = read_byte(fd_r);
    print("eof again: ");
    print_i32(eof2);
    println("");
    file_close(fd_r);

    // === Test 3: write_byte and read back ===
    let r_w2: Result<i32, str> = file_open_write("_test_io_tmp.txt");
    let fd_w2: i32 = match r_w2 {
        Result::Ok(v) => { v },
        Result::Err(e) => { println("open_write failed: {e}"); exit(1); 0 },
    };
    write_byte(fd_w2, 65);
    write_byte(fd_w2, 66);
    write_byte(fd_w2, 67);
    file_close(fd_w2);

    let r_r2: Result<i32, str> = file_open_read("_test_io_tmp.txt");
    let fd_r2: i32 = match r_r2 {
        Result::Ok(v) => { v },
        Result::Err(e) => { println("open_read failed: {e}"); exit(1); 0 },
    };
    let c1: i32 = read_byte(fd_r2);
    let c2: i32 = read_byte(fd_r2);
    let c3: i32 = read_byte(fd_r2);
    let c4: i32 = read_byte(fd_r2);
    print("byte A: ");
    print_i32(c1);
    println("");
    print("byte B: ");
    print_i32(c2);
    println("");
    print("byte C: ");
    print_i32(c3);
    println("");
    print("byte eof: ");
    print_i32(c4);
    println("");
    file_close(fd_r2);

    // === Test 4: write_byte with boundary values ===
    let r_w3: Result<i32, str> = file_open_write("_test_io_tmp.txt");
    let fd_w3: i32 = match r_w3 {
        Result::Ok(v) => { v },
        Result::Err(e) => { println("open_write failed: {e}"); exit(1); 0 },
    };
    write_byte(fd_w3, 0);
    write_byte(fd_w3, 255);
    write_byte(fd_w3, 127);
    file_close(fd_w3);

    let r_r3: Result<i32, str> = file_open_read("_test_io_tmp.txt");
    let fd_r3: i32 = match r_r3 {
        Result::Ok(v) => { v },
        Result::Err(e) => { println("open_read failed: {e}"); exit(1); 0 },
    };
    print("byte 0: ");
    print_i32(read_byte(fd_r3));
    println("");
    print("byte 255: ");
    print_i32(read_byte(fd_r3));
    println("");
    print("byte 127: ");
    print_i32(read_byte(fd_r3));
    println("");
    file_close(fd_r3);

    // === Test 5: file_delete returns Ok on success ===
    let del_ok: Result<str, str> = file_delete("_test_io_tmp.txt");
    match del_ok {
        Result::Ok(_) => { println("delete ok: 0"); },
        Result::Err(e) => { println("delete failed: {e}"); },
    };

    // === Test 6: open non-existent file returns Err ===
    let r_bad: Result<i32, str> = file_open_read("_no_such_file_ever.txt");
    match r_bad {
        Result::Ok(_) => { println("open missing: unexpected"); },
        Result::Err(_) => { println("open missing: -1"); },
    };

    // === Test 7: delete non-existent file fails ===
    let del_bad: Result<str, str> = file_delete("_no_such_file_ever.txt");
    match del_bad {
        Result::Ok(_) => { println("delete missing failed: false"); },
        Result::Err(_) => { println("delete missing failed: true"); },
    };

    println("all file_io tests passed");
}
