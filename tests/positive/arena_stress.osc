// Test: Arena stress — push enough elements to force the arena allocator
// past its 1 MB block boundary.  With i32 (4 bytes each), 300 000 elements
// need ~1.14 MB of contiguous capacity after doublings, which exceeds the
// default 1 MB arena block and forces a new block allocation.
// Also exercises many string concats and i32_to_str calls.

fn! main() {
    // Stress test 1: Push 300 000 elements to cross the 1 MB arena boundary
    let mut big: [i32] = [0];
    for i in 1..300000 {
        push(big, i);
    };
    print("big len: ");
    print_i32(len(big));
    println("");
    print("big[0]: ");
    print_i32(big[0]);
    println("");
    print("big[299999]: ");
    print_i32(big[299999]);
    println("");

    // Verify sum of first 1000 to catch corruption: 0+1+2+...+999 = 499500
    let mut sum: i32 = 0;
    for i in 0..1000 {
        sum = sum + big[i];
    };
    print("big sum: ");
    print_i32(sum);
    println("");

    // Stress test 2: Many string concatenations (each allocates from arena)
    let mut s: str = "";
    for i in 0..50 {
        s = str_concat(s, "x");
    };
    print("str len: ");
    print_i32(str_len(s));
    println("");

    // Stress test 3: Many i32_to_str calls (arena string allocations)
    let mut last: str = "";
    for i in 0..100 {
        last = i32_to_str(i);
    };
    println(last);

    println("arena stress OK");
}
