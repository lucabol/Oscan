fn! main() {
    // env_get success — try SYSTEMROOT (Windows) then PATH then HOME
    match env_get("SYSTEMROOT") {
        Result::Ok(val) => {
            print_bool(str_len(val) > 0);
            println("");
        },
        Result::Err(e1) => {
            match env_get("PATH") {
                Result::Ok(val2) => {
                    print_bool(str_len(val2) > 0);
                    println("");
                },
                Result::Err(e2) => {
                    match env_get("HOME") {
                        Result::Ok(val3) => {
                            print_bool(str_len(val3) > 0);
                            println("");
                        },
                        Result::Err(e3) => {
                            print_bool(false);
                            println("");
                        },
                    };
                },
            };
        },
    };

    // env_get failure (unlikely env var)
    match env_get("OSC_NONEXISTENT_VAR_12345") {
        Result::Ok(val) => { println(val); },
        Result::Err(e) => { println(e); },
    };

    // errno_get (should be >= 0)
    let e: i32 = errno_get();
    print_bool(e >= 0);
    println("");
}
