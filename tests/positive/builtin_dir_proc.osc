fn! main() {
    // dir_list
    let dc: Result<str, str> = dir_create("_oscan_test_ls");
    match dc {
        Result::Ok(_) => { },
        Result::Err(_) => { },
    };
    let r1: Result<i32, str> = file_open_write("_oscan_test_ls/a.txt");
    let fd1: i32 = match r1 {
        Result::Ok(fd) => { fd },
        Result::Err(_) => { -1 },
    };
    file_close(fd1);
    let r2: Result<i32, str> = file_open_write("_oscan_test_ls/b.txt");
    let fd2: i32 = match r2 {
        Result::Ok(fd) => { fd },
        Result::Err(_) => { -1 },
    };
    file_close(fd2);

    let files: [str] = dir_list("_oscan_test_ls");
    print_bool(len(files) >= 2);
    println("");

    // Cleanup
    let d1: Result<str, str> = file_delete("_oscan_test_ls/a.txt");
    match d1 {
        Result::Ok(_) => { },
        Result::Err(_) => { },
    };
    let d2: Result<str, str> = file_delete("_oscan_test_ls/b.txt");
    match d2 {
        Result::Ok(_) => { },
        Result::Err(_) => { },
    };
    let dr: Result<str, str> = dir_remove("_oscan_test_ls");
    match dr {
        Result::Ok(_) => { },
        Result::Err(_) => { },
    };

    // term_width and term_height return positive (or 0 if not a tty)
    let w: i32 = term_width();
    let h: i32 = term_height();
    print_bool(w >= 0);
    println("");
    print_bool(h >= 0);
    println("");

    println("dir_proc_ok");
}
