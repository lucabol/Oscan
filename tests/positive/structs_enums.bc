// Test: Struct and enum declarations and usage
// Exercises: struct declaration, struct literals, field access, enum declaration,
//            enum construction, match on enum, enum with payloads

struct Point {
    x: f64,
    y: f64,
}

enum Shape {
    Circle(f64),
    Rectangle(f64, f64),
    Dot(Point),
    Empty,
}

fn describe(s: Shape) -> str {
    match s {
        Shape::Circle(r) => "circle",
        Shape::Rectangle(w, h) => "rectangle",
        Shape::Dot(p) => "dot",
        Shape::Empty => "empty",
    }
}

fn area(s: Shape) -> f64 {
    match s {
        Shape::Circle(r) => 3.14159265358979 * r * r,
        Shape::Rectangle(w, h) => w * h,
        Shape::Dot(p) => 0.0,
        Shape::Empty => 0.0,
    }
}

fn! main() {
    let c: Shape = Shape::Circle(5.0);
    let r: Shape = Shape::Rectangle(3.0, 4.0);
    let p: Point = Point { x: 1.0, y: 2.0 };
    let d: Shape = Shape::Dot(p);
    let e: Shape = Shape::Empty;

    println(describe(c));
    print_f64(area(c));
    println("");

    println(describe(r));
    print_f64(area(r));
    println("");

    println(describe(d));
    print_f64(area(d));
    println("");

    println(describe(e));

    // Test struct field access
    let pt: Point = Point { x: 10.5, y: 20.3 };
    print("x = ");
    print_f64(pt.x);
    println("");
    print("y = ");
    print_f64(pt.y);
    println("");
}
