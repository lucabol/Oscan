// Test: Socket builtins accept hostnames now that laststanding resolves DNS/hosts entries.
// Uses localhost so the test stays offline and deterministic across platforms.

fn! main() {
    let tcp_port: i32 = 38451;
    let udp_port: i32 = 38452;

    let server: i32 = socket_tcp();
    let client: i32 = socket_tcp();
    if server < 0 or client < 0 {
        println("tcp setup failed");
    } else {
        let bind_status: i32 = socket_bind(server, tcp_port);
        let listen_status: i32 = socket_listen(server, 1);
        let mut peer: i32 = -1;

        if bind_status == 0 and listen_status == 0 {
            let connect_status: i32 = socket_connect(client, "localhost", tcp_port);
            if connect_status == 0 {
                peer = socket_accept(server);
            };
        };

        if peer < 0 {
            println("tcp localhost failed");
        } else {
            socket_send(client, "tcp localhost ok");
            println(socket_recv(peer, 64));
            socket_close(peer);
        };

        socket_close(client);
        socket_close(server);
    };

    let receiver: i32 = socket_udp();
    let sender: i32 = socket_udp();
    if receiver < 0 or sender < 0 {
        println("udp setup failed");
    } else {
        let bind_status: i32 = socket_bind(receiver, udp_port);
        let sent: i32 = if bind_status == 0 {
            socket_sendto(sender, "udp localhost ok", "localhost", udp_port)
        } else {
            -1
        };

        if sent < 0 {
            println("udp localhost failed");
        } else {
            println(socket_recvfrom(receiver, 64));
        };

        socket_close(sender);
        socket_close(receiver);
    };
}
