// Test: Socket builtins accept hostnames now that laststanding resolves DNS/hosts entries.
// Uses localhost so the test stays offline and deterministic across platforms.

fn! main() {
    let mut tcp_port: i32 = 38451;
    let mut udp_port: i32 = 39451;

    let sr: Result<i32, str> = socket_tcp();
    let server: i32 = match sr {
        Result::Ok(s) => { s },
        Result::Err(_) => { -1 },
    };
    let cr: Result<i32, str> = socket_tcp();
    let client: i32 = match cr {
        Result::Ok(s) => { s },
        Result::Err(_) => { -1 },
    };
    if server < 0 or client < 0 {
        println("tcp setup failed");
    } else {
        let mut bind_ok: bool = false;
        while not bind_ok and tcp_port < 38551 {
            let br: Result<str, str> = socket_bind(server, "127.0.0.1", tcp_port);
            bind_ok = match br {
                Result::Ok(_) => { true },
                Result::Err(_) => { false },
            };
            if not bind_ok {
                tcp_port = tcp_port + 1;
            };
        };
        let lr: Result<str, str> = socket_listen(server, 1);
        let listen_ok: bool = match lr {
            Result::Ok(_) => { true },
            Result::Err(_) => { false },
        };
        let mut peer: i32 = -1;

        if bind_ok and listen_ok {
            let cnr: Result<str, str> = socket_connect(client, "localhost", tcp_port);
            let connect_ok: bool = match cnr {
                Result::Ok(_) => { true },
                Result::Err(_) => { false },
            };
            if connect_ok {
                let ar: Result<i32, str> = socket_accept(server);
                peer = match ar {
                    Result::Ok(p) => { p },
                    Result::Err(_) => { -1 },
                };
            };
        };

        if peer < 0 {
            println("tcp localhost failed");
        } else {
            let snd: Result<i32, str> = socket_send(client, "tcp localhost ok");
            match snd {
                Result::Ok(_) => { },
                Result::Err(_) => { },
            };
            println(socket_recv(peer, 64));
            socket_close(peer);
        };

        socket_close(client);
        socket_close(server);
    };

    let rr: Result<i32, str> = socket_udp();
    let receiver: i32 = match rr {
        Result::Ok(s) => { s },
        Result::Err(_) => { -1 },
    };
    let snr: Result<i32, str> = socket_udp();
    let sender: i32 = match snr {
        Result::Ok(s) => { s },
        Result::Err(_) => { -1 },
    };
    if receiver < 0 or sender < 0 {
        println("udp setup failed");
    } else {
        let mut bind_ok: bool = false;
        while not bind_ok and udp_port < 39551 {
            let br2: Result<str, str> = socket_bind(receiver, "127.0.0.1", udp_port);
            bind_ok = match br2 {
                Result::Ok(_) => { true },
                Result::Err(_) => { false },
            };
            if not bind_ok {
                udp_port = udp_port + 1;
            };
        };
        let sent: i32 = if bind_ok {
            socket_sendto(sender, "udp localhost ok", "localhost", udp_port)
        } else {
            -1
        };

        if sent < 0 {
            println("udp localhost failed");
        } else {
            println(socket_recvfrom(receiver, 64));
        };

        socket_close(sender);
        socket_close(receiver);
    };
}
