// Regression test: gfx_text_width semantics for font id lookup.
// FONT_DEFAULT has fixed 8-px advance; FONT_PROPORTIONAL has per-glyph widths.
// Font ids match libs/fonts.osc: 0..3 are 8×8 variants (default, proportional,
// latin1, box); 4..7 are the matching 8×12 _L variants.
//
// On freestanding Windows/ARM builds OSC_HAS_GFX is defined and real
// measurements come through; on libc builds the gfx stubs return 0 for
// every call. Both modes are validated by the relaxed invariants below.

fn! main() {
    let s: str = "iiiiii";

    let w_default: i32 = gfx_text_width(s, 0);
    let w_prop: i32 = gfx_text_width(s, 1);
    let w_default_l: i32 = gfx_text_width(s, 4);
    let w_fallback: i32 = gfx_text_width(s, 99);

    // Width must never be negative.
    if w_default >= 0 and w_prop >= 0 and w_default_l >= 0 and w_fallback >= 0 {
        println("nonneg:ok");
    } else {
        println("nonneg:FAIL");
    };

    // Proportional is narrower than default for narrow glyphs. When gfx is
    // stubbed out (libc) both are 0, so we allow equality too.
    if w_prop <= w_default {
        println("proportional:ok");
    } else {
        println("proportional:FAIL=default={w_default} prop={w_prop}");
    };

    // The 8×12 _L variant shares the same advance (8 px) as FONT_DEFAULT for
    // monospace ASCII — only the cell height differs.
    if w_default_l == w_default {
        println("default_l:ok");
    } else {
        println("default_l:FAIL=default={w_default} default_l={w_default_l}");
    };

    // Unknown font ids must fall back to default.
    if w_fallback == w_default {
        println("fallback:ok");
    } else {
        println("fallback:FAIL={w_fallback}");
    };
}
